@* EstadoSistema.razor *@


@if (CodigoEstado == 200)
{
    <div class="estado-card estado-verde">
        <span class="estado-codigo">200</span>
        <span class="estado-mensaje">Sistema Operacional</span>
    </div>
}
else if (CodigoEstado == 404)
{
    <div class="estado-card estado-amarillo">
        <span class="estado-codigo">404</span>
        <span class="estado-mensaje">Recurso No Encontrado</span>
    </div>
}
else if (CodigoEstado == 500)
{
    <div class="estado-card estado-rojo">
        <span class="estado-codigo">500</span>
        <span class="estado-mensaje">Error Interno del Servidor</span>
    </div>
}
else
{
    <div class="estado-card estado-gris">
        <span class="estado-codigo">@CodigoEstado</span>
        <span class="estado-mensaje">Estado Desconocido</span>
    </div>
}

@code {
    [Parameter]
    public int CodigoEstado { get; set; }
}

<style>
    .estado-card {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 1.2rem;
        border-radius: 6px;
        margin-bottom: 0.5rem;
        font-family: sans-serif;
        font-size: 1rem;
    }

    .estado-codigo {
        font-weight: 700;
        font-size: 1.1rem;
    }

    .estado-verde {
        background-color: #d1fae5;
        color: #065f46;
        border: 1px solid #6ee7b7;
    }

    .estado-amarillo {
        background-color: #fef9c3;
        color: #854d0e;
        border: 1px solid #fde047;
    }

    .estado-rojo {
        background-color: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
    }

    .estado-gris {
        background-color: #f3f4f6;
        color: #374151;
        border: 1px solid #d1d5db;
    }
</style>
