@page "/actividades"
@rendermode InteractiveServer

<PageTitle>Actividades por hacer</PageTitle>

<h1>Lista de actividades</h1>

<div class="form-container">
    <div class="field-row">
        <input id="nueva"
               type="text"
               @bind="nuevaActividad"
               @bind:event="oninput"
               @onkeydown="TeclaPresionada"
               placeholder="Escribe una actividad..." />
        <button class="btn-agregar" @onclick="Agregar">+ Agregar</button>
    </div>

    @if (actividades.Count == 0)
    {
        <p class="vacio">No hay actividades pendientes.</p>
    }
    else
    {
        <ul class="lista">
            @foreach (var actividad in actividades.ToList())
            {
                <li class="item">
                    <span class="texto">@actividad</span>
                    <button class="btn-eliminar" @onclick="() => Eliminar(actividad)">Eliminar</button>
                </li>
            }
        </ul>
        <p class="total">Total: @actividades.Count actividad(es) pendiente(s)</p>
    }
</div>

@code {
    private List<string> actividades = new();
    private string nuevaActividad = "";

    private void Agregar()
    {
        string texto = nuevaActividad.Trim();
        if (!string.IsNullOrEmpty(texto))
        {
            actividades.Add(texto);
            nuevaActividad = "";
        }
    }

    private void Eliminar(string actividad)
    {
        actividades.Remove(actividad);
    }

    private void TeclaPresionada(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            Agregar();
    }
}

<style>
    h1 {
        font-size: 1.8rem;
        font-weight: 400;
        margin-bottom: 1.5rem;
        color: #212529;
    }

    .form-container {
        max-width: 700px;
        padding: 1rem 0;
    }

    .field-row {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .field-row input {
        flex: 1;
        padding: 0.5rem 0.75rem;
        font-size: 0.95rem;
        border: 1px solid #ced4da;
        border-radius: 4px;
        color: #495057;
    }

    .field-row input:focus {
        outline: none;
        border-color: #0d6efd;
        box-shadow: 0 0 0 2px rgba(13,110,253,0.2);
    }

    .btn-agregar {
        background-color: #0d6efd;
        color: #fff;
        border: none;
        padding: 0.5rem 1.25rem;
        font-size: 0.95rem;
        border-radius: 4px;
        cursor: pointer;
        white-space: nowrap;
        transition: background-color 0.15s ease;
    }

    .btn-agregar:hover  { background-color: #0b5ed7; }
    .btn-agregar:active { background-color: #0a58ca; }

    .lista {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid #f0f0f0;
        font-size: 0.95rem;
        color: #495057;
    }

    .item:nth-child(odd) {
        background-color: #f3f4f6;
    }

    .texto {
        flex: 1;
    }

    .btn-eliminar {
        background-color: #dc3545;
        color: #fff;
        border: none;
        padding: 0.3rem 0.8rem;
        font-size: 0.85rem;
        border-radius: 4px;
        cursor: pointer;
        margin-left: 1rem;
        transition: background-color 0.15s ease;
    }

    .btn-eliminar:hover  { background-color: #bb2d3b; }
    .btn-eliminar:active { background-color: #a52834; }

    .vacio {
        color: #6c757d;
        font-style: italic;
        margin-top: 1rem;
    }

    .total {
        margin-top: 1rem;
        font-size: 0.9rem;
        color: #6c757d;
    }
</style>
