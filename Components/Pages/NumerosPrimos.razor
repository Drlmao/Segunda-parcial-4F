@page "/numeros-primos"
@rendermode InteractiveServer

<PageTitle>Números primos</PageTitle>

<h1>Numeros primos</h1>

<div class="form-container">
    <div class="field-row">
        <label for="numero">Número entero</label>
        <input id="numero" type="number" min="1" @bind="numero" @bind:event="oninput" />
    </div>

    <div class="button-row">
        <button class="btn-generar" @onclick="GenerarPrimos">Generar primos</button>
    </div>

    @if (calculado)
    {
        <h3>Números primos</h3>
        @foreach (var p in primos)
        {
            <div class="numero-item">@p</div>
        }
    }
</div>

@code {
    private int numero = 0;
    private List<int> primos = new();
    private bool calculado = false;

    private void GenerarPrimos()
    {
        primos.Clear();

        for (int i = 2; i <= numero; i++)
        {
            if (EsPrimo(i))
                primos.Add(i);
        }

        calculado = true;
    }

    private bool EsPrimo(int n)
    {
        if (n < 2) return false;
        for (int i = 2; i <= Math.Sqrt(n); i++)
        {
            if (n % i == 0) return false;
        }
        return true;
    }
}

<style>
    h1 {
        font-size: 1.8rem;
        font-weight: 400;
        margin-bottom: 1.5rem;
        color: #212529;
    }

    h3 {
        font-size: 1.4rem;
        font-weight: 400;
        margin: 1rem 0 0.75rem 0;
        color: #212529;
    }

    .form-container {
        max-width: 700px;
        padding: 1rem 0;
    }

    .field-row {
        display: flex;
        align-items: center;
        margin-bottom: 1rem;
        gap: 1rem;
    }

    .field-row label {
        width: 110px;
        font-size: 0.95rem;
        color: #333;
    }

    .field-row input {
        flex: 1;
        padding: 0.45rem 0.75rem;
        font-size: 0.95rem;
        border: 1px solid #ced4da;
        border-radius: 4px;
        color: #495057;
        background-color: #fff;
    }

    .button-row {
        margin: 0.75rem 0 1rem 0;
    }

    .btn-generar {
        background-color: #0d6efd;
        color: #fff;
        border: none;
        padding: 0.5rem 1.25rem;
        font-size: 0.95rem;
        border-radius: 4px;
        cursor: pointer;
        transition: background-color 0.15s ease;
    }

    .btn-generar:hover  { background-color: #0b5ed7; }
    .btn-generar:active { background-color: #0a58ca; }

    .numero-item {
        padding: 0.5rem 0.75rem;
        font-size: 0.95rem;
        color: #495057;
        border-bottom: 1px solid #f0f0f0;
    }

    .numero-item:nth-child(odd) {
        background-color: #f3f4f6;
    }
</style>
